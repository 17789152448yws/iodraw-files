        </mxCell>
        <mxCell id="Ou2KXWs189Wuq3OIUBNO-118" value="靠近细胞表面的稳定保护层" style="shape=partialRectangle;html=1;whiteSpace=wrap;connectable=0;strokeColor=inherit;overflow=hidden;fillColor=none;top=0;left=0;bottom=0;right=0;pointerEvents=1;" vertex="1" parent="Ou2KXWs189Wuq3OIUBNO-116">
          <mxGeometry x="74" width="137" height="120" as="geometry">
            <mxRectangle width="137" height="120" as="alternateBounds" />
          </mxGeometry>
        </mxCell>
        <mxCell id="Ou2KXWs189Wuq3OIUBNO-119" value="&lt;li data-end=&quot;1785&quot; data-start=&quot;1736&quot; data-section-id=&quot;191vo16&quot;&gt;将提取完LB-EPS后的细胞沉淀再次加入 &lt;strong data-end=&quot;1776&quot; data-start=&quot;1760&quot;&gt;0.05% NaCl溶液&lt;/strong&gt;，补回50 mL。&lt;/li&gt;&lt;li data-end=&quot;1809&quot; data-start=&quot;1786&quot; data-section-id=&quot;1ehaeqf&quot;&gt;置于 &lt;strong data-end=&quot;1808&quot; data-start=&quot;1792&quot;&gt;60℃水浴 30 min&lt;/strong&gt;。&lt;/li&gt;&lt;li data-end=&quot;1820&quot; data-start=&quot;1810&quot; data-section-id=&quot;1qbu3k5&quot;&gt;立即冰浴冷却。&lt;/li&gt;&lt;li data-end=&quot;1860&quot; data-start=&quot;1821&quot; data-section-id=&quot;1g72rhj&quot;&gt;4℃，&lt;strong data-end=&quot;1859&quot; data-start=&quot;1827&quot;&gt;10000–15000 × g 离心 15–20 min&lt;/strong&gt;。&lt;/li&gt;&lt;li data-end=&quot;1869&quot; data-start=&quot;1861&quot; data-section-id=&quot;l6q72b&quot;&gt;收集上清。&lt;/li&gt;&lt;li data-end=&quot;1899&quot; data-start=&quot;1870&quot; data-section-id=&quot;utz9zw&quot;&gt;0.45 μm滤膜过滤，得到 &lt;strong data-end=&quot;1898&quot; data-start=&quot;1888&quot;&gt;TB-EPS&lt;/strong&gt;。&lt;/li&gt;" style="shape=partialRectangle;html=1;whiteSpace=wrap;connectable=0;strokeColor=inherit;overflow=hidden;fillColor=none;top=0;left=0;bottom=0;right=0;pointerEvents=1;align=left;" vertex="1" parent="Ou2KXWs189Wuq3OIUBNO-116">
          <mxGeometry x="211" width="278" height="120" as="geometry">
            <mxRectangle width="278" height="120" as="alternateBounds" />
          </mxGeometry>
        </mxCell>
        <mxCell id="Ou2KXWs189Wuq3OIUBNO-121" value="相同生长期的铜绿微囊藻培养液，建议使用&lt;strong data-end=&quot;916&quot; data-start=&quot;903&quot;&gt;对数后期或稳定前期并对其进行OD680、细胞密度、pH、DO、电导率、温度、培养时间的记录&lt;/strong&gt;" style="rounded=0;whiteSpace=wrap;html=1;" vertex="1" parent="Ou2KXWs189Wuq3OIUBNO-123">
          <mxGeometry width="609" height="60" as="geometry" />
        </mxCell>
        <mxCell id="Ou2KXWs189Wuq3OIUBNO-122" value="提取要求:&lt;li data-end=&quot;959&quot; data-start=&quot;938&quot; data-section-id=&quot;1g5odm3&quot;&gt;全程尽量在 &lt;strong data-end=&quot;956&quot; data-start=&quot;947&quot;&gt;4℃或冰上&lt;/strong&gt;操作。&lt;/li&gt;&lt;li data-end=&quot;982&quot; data-start=&quot;960&quot; data-section-id=&quot;75azl7&quot;&gt;每组至少设置 &lt;strong data-end=&quot;981&quot; data-start=&quot;970&quot;&gt;3个生物学重复&lt;/strong&gt;。&lt;/li&gt;&lt;li data-end=&quot;1018&quot; data-start=&quot;983&quot; data-section-id=&quot;mw6c4g&quot;&gt;记录提取前的 &lt;strong data-end=&quot;1017&quot; data-start=&quot;993&quot;&gt;OD680、细胞密度、pH、DO、电导率&lt;/strong&gt;。&lt;/li&gt;&lt;li data-end=&quot;1044&quot; data-start=&quot;1019&quot; data-section-id=&quot;106yy98&quot;&gt;所有离心管、滤膜、移液枪头尽量使用无菌耗材。&lt;/li&gt;" style="rounded=0;whiteSpace=wrap;html=1;" vertex="1" parent="Ou2KXWs189Wuq3OIUBNO-123">
          <mxGeometry x="489" y="60" width="120" height="425" as="geometry" />
        </mxCell>
        <mxCell id="Ou2KXWs189Wuq3OIUBNO-124" value="取50 mL铜绿微囊藻培养液，于4℃、3000 × g离心15 min，收集上清并经0.45 μm滤膜过滤，作为S-EPS。将沉淀用0.05% NaCl溶液重悬至原体积，轻柔涡旋1 min后，于4℃、5000 × g离心15 min，收集上清作为LB-EPS。随后将沉淀再次用0.05% NaCl重悬至原体积，于60℃水浴30 min，立即冰浴冷却，并于4℃、12000 × g离心20 min，收集上清作为TB-EPS。所有EPS样品经0.45 μm滤膜过滤后，根据后续分析需求进行即时检测、-80℃分装保存或冷冻干燥保存。" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="1759" y="552.5" width="321" height="140" as="geometry" />
        </mxCell>
        <mxCell id="Ou2KXWs189Wuq3OIUBNO-125" value="" style="shape=table;startSize=0;container=1;collapsible=0;childLayout=tableLayout;" vertex="1" parent="1">
