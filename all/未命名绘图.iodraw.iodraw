        <mxCell id="Ou2KXWs189Wuq3OIUBNO-111" value="&lt;br&gt;&lt;li data-end=&quot;1224&quot; data-start=&quot;1207&quot; data-section-id=&quot;1tvencz&quot;&gt;取 &lt;strong data-end=&quot;1223&quot; data-start=&quot;1212&quot;&gt;50 mL藻液&lt;/strong&gt;。&lt;/li&gt;&lt;li data-end=&quot;1259&quot; data-start=&quot;1225&quot; data-section-id=&quot;1ecyuuu&quot;&gt;4℃，&lt;strong data-end=&quot;1258&quot; data-start=&quot;1231&quot;&gt;2500–4000 × g 离心 15 min&lt;/strong&gt;。&lt;/li&gt;&lt;li data-end=&quot;1280&quot; data-start=&quot;1260&quot; data-section-id=&quot;1i87biz&quot;&gt;小心收集上清，不要扰动藻细胞沉淀。&lt;/li&gt;&lt;li data-end=&quot;1317&quot; data-start=&quot;1281&quot; data-section-id=&quot;aznopn&quot;&gt;上清经 &lt;strong data-end=&quot;1301&quot; data-start=&quot;1288&quot;&gt;0.45 μm滤膜&lt;/strong&gt;过滤，得到 &lt;strong data-end=&quot;1316&quot; data-start=&quot;1307&quot;&gt;S-EPS&lt;/strong&gt;&lt;/li&gt;&lt;li data-end=&quot;1363&quot; data-start=&quot;1318&quot; data-section-id=&quot;bc8qc1&quot;&gt;做EEM、TOC、蛋白、多糖，建议再用 &lt;strong data-end=&quot;1358&quot; data-start=&quot;1345&quot;&gt;0.22 μm滤膜&lt;/strong&gt;过滤一遍&lt;/li&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" style="shape=partialRectangle;html=1;whiteSpace=wrap;connectable=0;strokeColor=inherit;overflow=hidden;fillColor=none;top=0;left=0;bottom=0;right=0;pointerEvents=1;align=left;" parent="Ou2KXWs189Wuq3OIUBNO-108" vertex="1">
          <mxGeometry x="211" width="278" height="145" as="geometry">
            <mxRectangle width="278" height="145" as="alternateBounds" />
          </mxGeometry>
        </mxCell>
        <mxCell id="Ou2KXWs189Wuq3OIUBNO-112" value="" style="shape=tableRow;horizontal=0;startSize=0;swimlaneHead=0;swimlaneBody=0;strokeColor=inherit;top=0;left=0;bottom=0;right=0;collapsible=0;dropTarget=0;fillColor=none;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;" parent="Ou2KXWs189Wuq3OIUBNO-103" vertex="1">
          <mxGeometry y="185" width="489" height="120" as="geometry" />
        </mxCell>
        <mxCell id="Ou2KXWs189Wuq3OIUBNO-113" value="LB-EPS" style="shape=partialRectangle;html=1;whiteSpace=wrap;connectable=0;strokeColor=inherit;overflow=hidden;fillColor=none;top=0;left=0;bottom=0;right=0;pointerEvents=1;" parent="Ou2KXWs189Wuq3OIUBNO-112" vertex="1">
          <mxGeometry width="74" height="120" as="geometry">
            <mxRectangle width="74" height="120" as="alternateBounds" />
          </mxGeometry>
        </mxCell>
        <mxCell id="Ou2KXWs189Wuq3OIUBNO-114" value="外层动态软界面,最优先接触PBAT" style="shape=partialRectangle;html=1;whiteSpace=wrap;connectable=0;strokeColor=inherit;overflow=hidden;fillColor=none;top=0;left=0;bottom=0;right=0;pointerEvents=1;" parent="Ou2KXWs189Wuq3OIUBNO-112" vertex="1">
          <mxGeometry x="74" width="137" height="120" as="geometry">
            <mxRectangle width="137" height="120" as="alternateBounds" />
          </mxGeometry>
        </mxCell>
        <mxCell id="Ou2KXWs189Wuq3OIUBNO-115" value="&lt;li data-end=&quot;1510&quot; data-start=&quot;1462&quot; data-section-id=&quot;1pmkww8&quot;&gt;将上一步得到的藻细胞沉淀加入 &lt;strong data-end=&quot;1496&quot; data-start=&quot;1480&quot;&gt;0.05% NaCl溶&amp;nbsp; 液&lt;/strong&gt;，补回原体积，即50 mL。&lt;/li&gt;&lt;li data-end=&quot;1543&quot; data-start=&quot;1511&quot; data-section-id=&quot;128x39h&quot;&gt;轻轻吹打或低速涡旋 &lt;strong data-end=&quot;1535&quot; data-start=&quot;1524&quot;&gt;30–60 s&lt;/strong&gt;，不要强烈振荡。&lt;br&gt;&lt;/li&gt;&lt;li data-end=&quot;1581&quot; data-start=&quot;1544&quot; data-section-id=&quot;zeofon&quot;&gt;4℃，&lt;strong data-end=&quot;1580&quot; data-start=&quot;1550&quot;&gt;4000–5000 × g 离心 10–15 min&lt;/strong&gt;。&lt;/li&gt;&lt;li data-end=&quot;1590&quot; data-start=&quot;1582&quot; data-section-id=&quot;wtrioy&quot;&gt;收集上清。&lt;/li&gt;&lt;li data-end=&quot;1620&quot; data-start=&quot;1591&quot; data-section-id=&quot;f0f62v&quot;&gt;0.45 μm滤膜过滤，得到 &lt;strong data-end=&quot;1619&quot; data-start=&quot;1609&quot;&gt;LB-EPS&lt;/strong&gt;。&lt;/li&gt;" style="shape=partialRectangle;html=1;whiteSpace=wrap;connectable=0;strokeColor=inherit;overflow=hidden;fillColor=none;top=0;left=0;bottom=0;right=0;pointerEvents=1;align=left;" parent="Ou2KXWs189Wuq3OIUBNO-112" vertex="1">
          <mxGeometry x="211" width="278" height="120" as="geometry">
            <mxRectangle width="278" height="120" as="alternateBounds" />
          </mxGeometry>
        </mxCell>
        <mxCell id="Ou2KXWs189Wuq3OIUBNO-116" value="" style="shape=tableRow;horizontal=0;startSize=0;swimlaneHead=0;swimlaneBody=0;strokeColor=inherit;top=0;left=0;bottom=0;right=0;collapsible=0;dropTarget=0;fillColor=none;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;" parent="Ou2KXWs189Wuq3OIUBNO-103" vertex="1">
          <mxGeometry y="305" width="489" height="120" as="geometry" />
        </mxCell>
        <mxCell id="Ou2KXWs189Wuq3OIUBNO-117" value="TB-EPS" style="shape=partialRectangle;html=1;whiteSpace=wrap;connectable=0;strokeColor=inherit;overflow=hidden;fillColor=none;top=0;left=0;bottom=0;right=0;pointerEvents=1;" parent="Ou2KXWs189Wuq3OIUBNO-116" vertex="1">
