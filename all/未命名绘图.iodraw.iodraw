        <mxCell id="Ou2KXWs189Wuq3OIUBNO-111" value="&lt;br&gt;&lt;li data-end=&quot;1224&quot; data-start=&quot;1207&quot; data-section-id=&quot;1tvencz&quot;&gt;取 &lt;strong data-end=&quot;1223&quot; data-start=&quot;1212&quot;&gt;50 mL藻液&lt;/strong&gt;。&lt;/li&gt;&lt;li data-end=&quot;1259&quot; data-start=&quot;1225&quot; data-section-id=&quot;1ecyuuu&quot;&gt;4℃，&lt;strong data-end=&quot;1258&quot; data-start=&quot;1231&quot;&gt;2500–4000 × g 离心 15 min&lt;/strong&gt;。&lt;/li&gt;&lt;li data-end=&quot;1280&quot; data-start=&quot;1260&quot; data-section-id=&quot;1i87biz&quot;&gt;小心收集上清，不要扰动藻细胞沉淀。&lt;/li&gt;&lt;li data-end=&quot;1317&quot; data-start=&quot;1281&quot; data-section-id=&quot;aznopn&quot;&gt;上清经 &lt;strong data-end=&quot;1301&quot; data-start=&quot;1288&quot;&gt;0.45 μm滤膜&lt;/strong&gt;过滤，得到 &lt;strong data-end=&quot;1316&quot; data-start=&quot;1307&quot;&gt;S-EPS&lt;/strong&gt;&lt;/li&gt;&lt;li data-end=&quot;1363&quot; data-start=&quot;1318&quot; data-section-id=&quot;bc8qc1&quot;&gt;做EEM、TOC、蛋白、多糖，建议再用 &lt;strong data-end=&quot;1358&quot; data-start=&quot;1345&quot;&gt;0.22 μm滤膜&lt;/strong&gt;过滤一遍&lt;/li&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" style="shape=partialRectangle;html=1;whiteSpace=wrap;connectable=0;strokeColor=inherit;overflow=hidden;fillColor=none;top=0;left=0;bottom=0;right=0;pointerEvents=1;align=left;" vertex="1" parent="Ou2KXWs189Wuq3OIUBNO-108">
          <mxGeometry x="211" width="278" height="145" as="geometry">
            <mxRectangle width="278" height="145" as="alternateBounds" />
          </mxGeometry>
        </mxCell>
